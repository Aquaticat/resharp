          "default": false,
          "type": "boolean"
        },
        "input": {
          "default": "",
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "pattern": {
          "type": "string"
        },
        "rev_nulls": {
          "type": "array",
          "items": {
            "type": "integer",
            "format": "uint",
            "minimum": 0.0
