{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RevNullsFile",
  "type": "object",
  "required": [
    "test"
  ],
  "properties": {
    "description": {
      "default": null,
      "type": [
        "string",
        "null"
      ]
    },
    "test": {
