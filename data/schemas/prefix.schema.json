        "kind": {
          "type": [
            "string",
            "null"
          ]
        },
        "name": {
          "type": "string"
        },
        "pattern": {
          "type": "string"
        },
        "potential_fwd": {
          "type": [
            "string",
            "null"
          ]
        },
        "potential_rev": {
          "type": [
            "string",
            "null"
          ]
        },
        "prefix_rev": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    }
  }
