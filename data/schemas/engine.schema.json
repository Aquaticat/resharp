{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "EngineFile",
  "type": "object",
  "required": [
    "test"
  ],
  "properties": {
    "description": {
      "default": null,
      "type": [
        "string",
        "null"
      ]
    },
    "test": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/EngineCase"
      }
    }
  },
  "additionalProperties": false,
  "definitions": {
    "EngineCase": {
      "type": "object",
      "required": [
        "pattern"
      ],
      "properties": {
        "anchored": {
          "default": false,
          "type": "boolean"
        },
        "ascii": {
          "default": false,
          "type": "boolean"
        },
        "expect_error": {
          "default": false,
          "type": "boolean"
        },
        "ignore": {
          "default": false,
          "type": "boolean"
        },
        "input": {
          "default": "",
          "type": "string"
        },
        "matches": {
          "default": [],
          "type": "array",
          "items": {
            "type": "array",
            "items": {
              "type": "integer",
              "format": "uint",
              "minimum": 0.0
            },
            "maxItems": 2,
            "minItems": 2
          }
        },
        "name": {
          "default": "",
          "type": "string"
        },
        "pattern": {
          "type": "string"
        },
        "reason": {
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "supported": {
          "default": null,
          "type": [
            "boolean",
            "null"
          ]
        },
        "vs_find_all": {
          "default": false,
          "type": "boolean"
        },
        "vs_regex": {
          "default": false,
          "type": "boolean"
        }
      },
      "additionalProperties": false
    }
  }
}